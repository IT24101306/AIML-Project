# Copy to .env and fill in. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional — default is claude-sonnet-4-6 (see Anthropic docs for IDs)
# ANTHROPIC_MODEL=claude-haiku-4-5
# Optional: cap rows per upload for speed (omit or 0 = process entire CSV)
# MONTHLY_BATCH_MAX_ROWS=2000

# MongoDB — used by POST /api/sync_from_mongo ("Sync from database" in the UI)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
# MONGODB_DB=hotel
# MONGODB_REVIEWS_COLLECTION=reviews
# Only documents with status "active" (set to false to sync all documents with text)
# MONGODB_SYNC_ONLY_ACTIVE=true
# Optional extra find() filter as JSON (merged with active filter). Use BSON types pymongo understands.
# MONGODB_SYNC_FILTER={"customerNumber": 2}
# If review body uses a non-standard field name only:
# MONGODB_REVIEW_TEXT_FIELD=text

# Sentiment: text classifier (LogisticRegression) + star rating fusion
# REVIEW_RATING_MAX=auto|5|10   (auto: values ≤5.5 treated as 1–5 stars, else 1–10)
# SENTIMENT_FUSION_TEXT_WEIGHT=0.55
# SENTIMENT_FUSION_STAR_WEIGHT=0.45
